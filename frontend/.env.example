# ─── API URL ─────────────────────────────────────────────────────────────────────
# Development (Replit preview or local):  use your Replit dev URL or localhost
# Production (Vercel):                    use your ngrok public URL
#
# IMPORTANT: This MUST match the public URL your Termux backend is exposed on.
# When ngrok restarts, this URL changes — update it in Vercel's env vars and redeploy.
#
# Examples:
#   Development:  VITE_API_URL=http://localhost:5000
#   Replit dev:   VITE_API_URL=https://your-replit-dev-domain.replit.dev
#   Production:   VITE_API_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app
VITE_API_URL=http://localhost:5000
