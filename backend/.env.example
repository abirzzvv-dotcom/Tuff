# ─── DATABASE ───────────────────────────────────────────────────────────────────
# 
# Neon PostgreSQL connection string
# Get from: https://neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── SERVER ─────────────────────────────────────────────────────────────────────
PORT=5000

# ─── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For development: http://localhost:5173
# For production: https://yourapp.vercel.app
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:5173,https://yourapp.vercel.app

# ─── EMAIL (Gmail SMTP) ─────────────────────────────────────────────────────────
# Your Gmail address
EMAIL_USER=your.email@gmail.com
# Gmail App Password (NOT your normal Gmail password)
# How to get it: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── NGROK ──────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
# Set to "true" to enable verbose ngrok logging
NGROK_DEBUG=false

# ─── NVIDIA AI ──────────────────────────────────────────────────────────────────
# Get from: https://build.nvidia.com → API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PROJECTS ───────────────────────────────────────────────────────────────────
# Directory where user projects are stored on Termux
# Default: ~/projects  (e.g. /data/data/com.termux/files/home/projects)
# PROJECTS_DIR=/data/data/com.termux/files/home/projects
